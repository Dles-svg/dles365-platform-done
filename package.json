{
  "name": "project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev:gamer": "NODE_ENV=development electron electron-gamer/main.js",
    "electron:dev:miner": "NODE_ENV=development electron electron-miner/main.js",
    "electron:build:gamer": "npm run build && electron-builder --config electron-builder-gamer.json",
    "electron:build:miner": "npm run build && electron-builder --config electron-builder-miner.json",
    "electron:build:all": "npm run build && npm run electron:build:gamer && npm run electron:build:miner"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
