{
  "appId": "com.daylight.es365.gamer",
  "productName": "Daylight ES365 Gamer",
  "directories": {
    "output": "dist-electron/gamer"
  },
  "files": [
    "dist/**/*",
    "electron-gamer/**/*",
    "public/daylight-logo.jpg"
  ],
  "extraMetadata": {
    "main": "electron-gamer/main.js"
  },
  "win": {
    "target": [
      "nsis"
    ],
    "icon": "public/daylight-logo.jpg"
  },
  "mac": {
    "target": [
      "dmg"
    ],
    "icon": "public/daylight-logo.jpg",
    "category": "public.app-category.entertainment"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "icon": "public/daylight-logo.jpg",
    "category": "Game"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
